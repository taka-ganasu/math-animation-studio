        title = self.make_label("最後に重みを少し直す", font_size=30)
        title.to_edge(UP, buff=0.35)
        formula = self.make_math(
            r"W\leftarrow W-\eta\frac{\partial L}{\partial W}",
            "W <- W - eta * gradient",
