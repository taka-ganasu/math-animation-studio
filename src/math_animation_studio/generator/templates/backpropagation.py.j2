        )
        formula.move_to(UP * 1.55)
        old_weight = self.make_label(f"今の重み: {SELECTED_WEIGHT_BEFORE:.3f}", font_size=23, color=WHITE)
        grad = self.make_label(f"勾配: {SELECTED_WEIGHT_GRADIENT:+.3f}", font_size=23, color=ORANGE)
        new_weight = self.make_label(f"更新後: {SELECTED_WEIGHT_AFTER:.3f}", font_size=23, color=GREEN_B)
        rows = VGroup(old_weight, grad, new_weight).arrange(DOWN, aligned_edge=LEFT, buff=0.25)
        rows.move_to(LEFT * 2.4 + DOWN * 0.25)
        edge = Line(LEFT * 1.0 + DOWN * 0.4, RIGHT * 2.1 + DOWN * 0.4, color=YELLOW, stroke_width=7)
        dot_left = Dot(edge.get_start(), color=GREEN_B)
        dot_right = Dot(edge.get_end(), color=YELLOW)
        edge_label = self.make_label("1本の接続重み", font_size=21, color=YELLOW)
        edge_label.next_to(edge, DOWN, buff=0.25)
        caption = self.make_label("勾配が負なら、重みは少し大きくなります", font_size=20, color=YELLOW)
        caption.to_edge(DOWN, buff=0.35)

        self.play(FadeIn(title), Write(formula), run_time=0.9)
        self.play(Create(edge), FadeIn(dot_left), FadeIn(dot_right), FadeIn(edge_label), run_time=0.8)
        self.play(FadeIn(old_weight), run_time=0.45)
        self.play(FadeIn(grad), run_time=0.45)
        self.play(TransformFromCopy(old_weight, new_weight), FadeIn(caption), run_time=0.8)
        self.wait_remaining(duration, 3.4)
        self.play(FadeOut(VGroup(title, formula, rows, edge, dot_left, dot_right, edge_label, caption)), run_time=0.35)

