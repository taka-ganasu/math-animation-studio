        self.wait_remaining(duration, min(1.5, duration * 0.35) + min(1.8, duration * 0.36))

        shallow_point = (-1.41, 0.73, self.loss(-1.41, 0.73))
        deep_point = (1.33, -0.64, self.loss(1.33, -0.64))
        shallow_dot = Dot(axes.c2p(shallow_point[0], shallow_point[1]), color=YELLOW, radius=0.09)
        deep_dot = Dot(axes.c2p(deep_point[0], deep_point[1]), color=GREEN, radius=0.09)
        shallow_label = Text("浅い局所最小", font_size=22, color=YELLOW)
        shallow_label.next_to(shallow_dot, LEFT, buff=0.15)
        deep_label = Text("深い大域最小", font_size=22, color=GREEN)
        deep_label.next_to(deep_dot, RIGHT, buff=0.15)
        next_caption = self.make_caption("左の谷は局所最小、右の谷はより低い大域最小です。")
        duration = segment_duration("two_valleys", 6.0)
        self.play(
            FadeIn(shallow_dot),
            FadeIn(deep_dot),
            FadeIn(shallow_label),
            FadeIn(deep_label),
            ReplacementTransform(caption, next_caption),
            run_time=min(1.1, duration * 0.28),
        )
        caption = next_caption
        self.wait_remaining(duration, min(1.1, duration * 0.28))

        start = left_points[0]
        start_dot = Dot(self.point2d(axes, start), color=RED, radius=0.08)
        start_label = Text("現在地", font_size=20, color=RED)
        start_label.next_to(start_dot, UP, buff=0.12)
        arrow = self.gradient_arrow_2d(axes, start[0], start[1], RED)
        arrow_label = Text("負の勾配方向", font_size=20, color=RED)
        arrow_label.next_to(arrow, UP, buff=0.08)
        next_caption = self.make_caption("勾配は今いる場所の上り方向です。下るには逆向きへ進みます。")
        duration = segment_duration("local_slope", 6.0)
        self.play(
            FadeIn(start_dot),
            FadeIn(start_label),
            GrowArrow(arrow),
            FadeIn(arrow_label),
            ReplacementTransform(caption, next_caption),
            run_time=min(1.25, duration * 0.3),
        )
        caption = next_caption
        self.wait_remaining(duration, min(1.25, duration * 0.3))
        self.play(FadeOut(start_dot), FadeOut(start_label), FadeOut(arrow), FadeOut(arrow_label), run_time=0.25)

        next_caption = self.make_caption("左側から始めると、近くの浅い谷へ吸い込まれます。")
        duration = segment_duration("left_descent", 8.0)
        self.play(ReplacementTransform(caption, next_caption), run_time=0.35)
        caption = next_caption
        left_dot, left_path = self.play_descent_path_2d(
            axes,
            left_points,
            color=YELLOW,
            duration=max(0.5, duration - 0.35),
            label="start A",
        )

        next_caption = self.make_caption("右側から始めると、より深い谷へ向かいます。")
        duration = segment_duration("right_descent", 8.0)
        self.play(ReplacementTransform(caption, next_caption), run_time=0.35)
        caption = next_caption
        right_dot, right_path = self.play_descent_path_2d(
            axes,
            right_points,
            color=GREEN,
            duration=max(0.5, duration - 0.35),
            label="start B",
        )

        boundary = DashedLine(
            axes.c2p(-0.08, Y_RANGE[0] + 0.1),
            axes.c2p(-0.08, Y_RANGE[1] - 0.1),
            dash_length=0.12,
            color=GREY_B,
            stroke_width=3,
        )
        boundary_label = Text("初期位置で分かれる境界のイメージ", font_size=19, color=GREY_B)
        boundary_label.next_to(boundary, UP, buff=0.12)
        left_badge = self.final_loss_badge("A: 局所最小", left_points[-1], YELLOW)
        right_badge = self.final_loss_badge("B: 大域最小", right_points[-1], GREEN)
        badges = VGroup(left_badge, right_badge).arrange(DOWN, buff=0.18)
        badges.to_corner(UR, buff=0.55)
        next_caption = self.make_caption("勾配降下法は谷を見比べません。初期位置と局所的な傾きで行き先が決まります。")
        duration = segment_duration("compare_minima", 7.0)
        self.play(
            FadeIn(boundary),
            FadeIn(boundary_label),
            FadeIn(badges),
            ReplacementTransform(caption, next_caption),
            run_time=min(1.2, duration * 0.3),
        )
        caption = next_caption
        self.wait_remaining(duration, min(1.2, duration * 0.3))

        jitter = self.sgd_jitter_path(axes, left_points)
        sgd_note = Text("SGD: 勾配にミニバッチ由来の揺れが入る", font_size=22, color=ORANGE)
        sgd_note.to_corner(UL, buff=0.55)
        next_caption = self.make_caption("SGDでは軌跡が少し揺れます。ただし、常に深い谷を選べるわけではありません。")
        duration = segment_duration("sgd_bridge", 7.0)
        self.play(
            FadeIn(jitter),
            FadeIn(sgd_note),
            ReplacementTransform(caption, next_caption),
            run_time=min(1.25, duration * 0.32),
        )
        caption = next_caption
        self.wait_remaining(duration, min(1.25, duration * 0.32))

        summary_formula = self.make_math(
            r"\theta_{t+1}=\theta_t-\eta\nabla L(\theta_t)",
            "theta_next = theta - eta grad L",
            font_size=34,
        )
        summary_formula.move_to(ORIGIN + DOWN * 2.55)
        summary_box = SurroundingRectangle(summary_formula, color=YELLOW, buff=0.12)
        next_caption = self.make_caption("まとめると、勾配降下法は現在地の斜面だけを見て一歩ずつ下ります。")
        duration = segment_duration("summary", 5.0)
        self.play(
            FadeIn(summary_formula),
            Create(summary_box),
            ReplacementTransform(caption, next_caption),
            run_time=min(1.0, duration * 0.32),
        )
        self.wait_remaining(duration, min(1.0, duration * 0.32))

    def construct(self) -> None:
        if VISUALIZATION_STYLE == "double_well_1d":
            self.construct_double_well_1d()
            return
        if VISUALIZATION_STYLE == "double_well_2d":
            self.construct_double_well_2d()
            return

        points = self.descent_points()
        max_z = max([point[2] for point in points] + [6.0])

        axes = ThreeDAxes(
            x_range=[X_RANGE[0], X_RANGE[1], 1],
            y_range=[Y_RANGE[0], Y_RANGE[1], 1],
            z_range=[0, max_z + 1.0, 1],
            x_length=6.4,
            y_length=6.4,
            z_length=3.6,
        )
        axes.shift(DOWN * 0.75)

        surface = Surface(
            lambda u, v: axes.c2p(u, v, self.loss(u, v)),
            u_range=[X_RANGE[0], X_RANGE[1]],
            v_range=[Y_RANGE[0], Y_RANGE[1]],
            resolution=(32, 32),
        )
        surface.set_style(fill_opacity=0.58, stroke_color=BLUE_E, stroke_width=0.35)
        surface.set_fill(BLUE_D, opacity=0.58)

        title = Text(TITLE, font_size=30)
        title.to_edge(UP)
        try:
            formula = MathTex(FORMULA_LATEX, font_size=32)
        except FileNotFoundError:
            formula = Text(FORMULA_FALLBACK_TEXT, font_size=28)
        formula.next_to(title, DOWN, buff=0.2)
        note = Text("negative gradient = downhill step", font_size=22)
        note.next_to(formula, DOWN, buff=0.2)

        self.set_camera_orientation(phi=63 * DEGREES, theta=-42 * DEGREES, zoom=0.82)
        self.add_fixed_in_frame_mobjects(title, formula, note)
        self.play(FadeIn(title), Write(formula), FadeIn(note), run_time=1.4)
        self.play(Create(axes), FadeIn(surface), run_time=2.2)

        dot = Sphere(radius=0.09, resolution=(12, 12))
        dot.set_color(RED)
        dot.move_to(axes.c2p(*points[0]))
        self.play(FadeIn(dot), run_time=0.5)

        path_segments = VGroup()
        for index, start in enumerate(points[:-1]):
            end = points[index + 1]
            start_point = axes.c2p(*start)
            end_point = axes.c2p(*end)

            direction = -self.gradient(start[0], start[1])
            norm = float(np.linalg.norm(direction))
            arrow = None
            if norm > 1.0e-8:
                arrow_xy = np.array([start[0], start[1]]) + 0.45 * direction / norm
                arrow_z = self.loss(float(arrow_xy[0]), float(arrow_xy[1]))
                arrow = Arrow3D(
                    start=start_point,
                    end=axes.c2p(float(arrow_xy[0]), float(arrow_xy[1]), arrow_z),
                    color=YELLOW,
                )
                self.play(FadeIn(arrow), run_time=0.12)

            segment = Line(start_point, end_point, color=YELLOW)
            segment.set_stroke(width=5)
            path_segments.add(segment)
            self.play(dot.animate.move_to(end_point), Create(segment), run_time=0.18)

            if arrow is not None:
                self.play(FadeOut(arrow), run_time=0.06)

        summary = Text(
            "Move a little opposite to the gradient.",
            font_size=24,
        )
        summary.to_edge(DOWN)
        self.add_fixed_in_frame_mobjects(summary)
        self.play(FadeIn(summary), run_time=0.8)
        self.wait(2.0)
