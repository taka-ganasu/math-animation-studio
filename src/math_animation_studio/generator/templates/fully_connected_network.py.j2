            y_length=3.1,
            tips=False,
        )
        axes.shift(DOWN * 0.45)
        curve = axes.plot(lambda x: -math.log(x), x_range=[0.05, 1.0], color=YELLOW)
        dot = Dot(axes.c2p(probability, CROSS_ENTROPY_LOSS), color=RED_B, radius=0.08)
        dot_label = self.make_label(f"p={probability:.2f}", font_size=19, color=RED_B)
        dot_label.next_to(dot, UP, buff=0.1)
        caption = self.bottom_caption("正解確率が高いほど、損失は小さくなります", bottom_buff=0.25)

        self.play(FadeIn(title), Write(formula), run_time=1.0)
        self.play(Create(axes), Create(curve), run_time=1.2)
        self.play(FadeIn(dot), FadeIn(dot_label), FadeIn(caption), run_time=0.7)
        self.wait_remaining(duration, 2.9)
        self.play(FadeOut(VGroup(title, formula, axes, curve, dot, dot_label, caption)), run_time=0.35)

