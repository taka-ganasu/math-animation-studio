    def probability_bars(self, *, center, color: ManimColor = YELLOW) -> VGroup:
        group = VGroup()
        base = center + LEFT * 1.35 + DOWN * 1.15
        max_height = 2.6
        baseline = Line(base + LEFT * 0.35, base + RIGHT * 2.7, color=GRAY_B, stroke_width=2)
        group.add(baseline)
        for index, (label, probability) in enumerate(zip(CLASS_LABELS, PROBABILITIES)):
            height = max(0.06, float(probability) * max_height)
            x = base + RIGHT * (index * 1.05)
            bar = Rectangle(
                width=0.56,
                height=height,
                stroke_color=color,
                stroke_width=2,
                fill_color=color,
                fill_opacity=0.8,
            )
            bar.move_to(x + UP * (height / 2))
            label_text = self.make_label(str(label), font_size=18, color=WHITE)
            label_text.next_to(bar, DOWN, buff=0.16)
            value_text = self.make_label(f"{probability:.2f}", font_size=18, color=color)
            value_text.next_to(bar, UP, buff=0.12)
            group.add(bar, label_text, value_text)
        return group

